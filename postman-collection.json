  "item": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticación (públicos excepto logout)",
      "item": [
        {
          "name": "POST /auth/register/user",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register/user",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register", "user"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123\",\n  \"role\": \"TeamAdmin\"\n}"
            },
            "description": "Registra un nuevo usuario. Retorna tokens de autenticación."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201/200', function () { pm.expect([200,201]).to.include(pm.response.code); });",
                  "if ([200,201].includes(pm.response.code)) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken || json.refresh_token);",
                  "    pm.collectionVariables.set('userId', json.user?.id || json.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /auth/register/client",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register/client",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register", "client"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Cliente ACME\",\n  \"email\": \"cliente@acme.com\",\n  \"password\": \"Password123\"\n}"
            },
            "description": "Registra un nuevo cliente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201/200', function () { pm.expect([200,201]).to.include(pm.response.code); });",
                  "if ([200,201].includes(pm.response.code)) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('clientId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /auth/login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
