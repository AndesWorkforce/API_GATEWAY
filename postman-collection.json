{
  "info": {
    "name": "Proyecto-Metricas API Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "accessToken", "value": "" },
    { "key": "appId", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "teamId", "value": "" },
    { "key": "contractorId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "agentId", "value": "" },
    { "key": "agentSessionId", "value": "" },
    { "key": "dayOffId", "value": "" },
    { "key": "activationKey", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Si el request marca noAuth, no agregar Authorization",
          "if (pm.request && pm.request.headers && pm.request.headers.has('X-No-Auth')) {",
          "  pm.request.headers.remove('Authorization');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [ {"key":"X-No-Auth","value":"1"} ],
            "url": { "raw": "{{baseUrl}}/auth/register/user", "host": ["{{baseUrl}}"], "path": ["auth","register","user"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"User Name\",\n  \"role\": \"Visualizer\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res?.accessToken || res?.access_token || res?.token;",
                  "if (token) { pm.environment.set('accessToken', token); pm.collectionVariables.set('accessToken', token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Client",
          "request": {
            "method": "POST",
            "header": [ {"key":"X-No-Auth","value":"1"} ],
            "url": { "raw": "{{baseUrl}}/auth/register/client", "host": ["{{baseUrl}}"], "path": ["auth","register","client"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Client Name\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res?.accessToken || res?.access_token || res?.token;",
                  "if (token) { pm.environment.set('accessToken', token); pm.collectionVariables.set('accessToken', token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ {"key":"X-No-Auth","value":"1"} ],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res?.accessToken || res?.access_token || res?.token;",
                  "if (token) { pm.environment.set('accessToken', token); pm.collectionVariables.set('accessToken', token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [ {"key":"X-No-Auth","value":"1"} ],
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth","refresh-token"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{accessToken}}\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [ {"key":"X-No-Auth","value":"1"} ],
            "url": { "raw": "{{baseUrl}}/auth/validate?token={{accessToken}}", "host": ["{{baseUrl}}"], "path": ["auth","validate"], "query": [{"key":"token","value":"{{accessToken}}"}] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] },
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {"raw": {"language": "json"}}
            }
          }
        }
      ]
    },
